# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Market Data — Alpaca is the primary provider (free paper account works).
# Sign up: https://alpaca.markets/  -> create paper account -> generate API keys
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# News + earnings calendar (Finnhub free tier, 60 calls/min).
# Sign up: https://finnhub.io/  -> dashboard -> API Key
FINNHUB_API_KEY=

# Optional fallback options data source
TRADIER_API_KEY=

# Unused unless you migrate to broker execution / additional providers
POLYGON_API_KEY=
UNUSUAL_WHALES_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# LLM
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# OpenClaw gateway (currently optional for Talon)
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=

# System
TALON_MODE=shadow
TALON_DB_PATH=./data/talon.db
TALON_LOG_LEVEL=INFO
DAILY_TOKEN_BUDGET_USD=5.00
